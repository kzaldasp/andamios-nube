# Copia este archivo como .env.local y completa los valores.
# Para probar en esta computadora (sin internet) se puede usar un archivo local:
#   TURSO_DATABASE_URL=file:datos-local.db
# Para producción, los valores los da Turso (turso.tech):
TURSO_DATABASE_URL=libsql://TU-BASE-DE-DATOS.turso.io
TURSO_AUTH_TOKEN=TU-TOKEN-SECRETO
